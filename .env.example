# Environment Variables for CropFresh AI Service
# ================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables marked [Required] must be set.
# Variables marked [Optional] have sensible defaults.

# ═══════════════════════════════════════════════════════════════
# LLM Configuration [Required]
# ═══════════════════════════════════════════════════════════════
GROQ_API_KEY=gsk_your_api_key_here

# LLM Provider: groq | openrouter | vllm
LLM_PROVIDER=groq
# LLM Model (Groq-hosted Llama)
LLM_MODEL=llama-3.3-70b-versatile

# ═══════════════════════════════════════════════════════════════
# Deployment
# ═══════════════════════════════════════════════════════════════
# Environment: development | staging | production
ENVIRONMENT=development

API_HOST=0.0.0.0
API_PORT=8000
# Never set DEBUG=true in production — disables Swagger docs
DEBUG=false
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════
# Security [Required in staging/production]
# ═══════════════════════════════════════════════════════════════
# API key clients must send in the X-API-Key header.
# Leave blank for local development (auth is auto-skipped).
API_KEY=

# Comma-separated CORS allowed origins.
# Use * for local dev only. Example for prod:
#   ALLOWED_ORIGINS=https://app.cropfresh.in,https://admin.cropfresh.in
ALLOWED_ORIGINS=*

# ═══════════════════════════════════════════════════════════════
# Vector Database [Required for RAG]
# ═══════════════════════════════════════════════════════════════
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
# Collection name in Qdrant
QDRANT_COLLECTION=agri_knowledge

# ═══════════════════════════════════════════════════════════════
# Redis Cache [Required for cost optimization]
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════════════════
# Supabase (PostgreSQL) [Required for marketplace features]
# ═══════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ═══════════════════════════════════════════════════════════════
# Neo4j (Graph DB) [Required for buyer-seller matching]
# ═══════════════════════════════════════════════════════════════
NEO4J_URI=neo4j+s://your-project.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ═══════════════════════════════════════════════════════════════
# Observability [Optional — enables distributed tracing]
# ═══════════════════════════════════════════════════════════════
# OTLP gRPC endpoint for OpenTelemetry traces.
# Example: http://localhost:4317 (local OTel Collector)
OTEL_ENDPOINT=

# LangSmith for agent evaluation & prompt tracking
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cropfresh-ai

# Grafana admin password (docker-compose only)
GRAFANA_PASSWORD=cropfresh123

# ═══════════════════════════════════════════════════════════════
# AI Kosha (India AI Dataset Platform) [Optional]
# Register at https://indiaai.gov.in/ai-kosha
# ═══════════════════════════════════════════════════════════════
AIKOSHA_API_KEY=
AIKOSHA_BASE_URL=https://indiaai.gov.in/api/v1

# ═══════════════════════════════════════════════════════════════
# External Data APIs [Optional]
# ═══════════════════════════════════════════════════════════════
AGMARKNET_API_KEY=
WEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=

# ═══════════════════════════════════════════════════════════════
# Web Scraping
# ═══════════════════════════════════════════════════════════════
SCRAPING_RATE_LIMIT=30
SCRAPING_CACHE_TTL=300

# ═══════════════════════════════════════════════════════════════
# Feature Flags
# ═══════════════════════════════════════════════════════════════
USE_ADAPTIVE_ROUTER=true
USE_REDIS_CACHE=true
ENABLE_RERANKER=true

# ═══════════════════════════════════════════════════════════════
# n8n Workflow Engine (docker-compose)
# ═══════════════════════════════════════════════════════════════
N8N_PASSWORD=cropfresh123

# ═══════════════════════════════════════════════════════════════
# CropFresh AI — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.
# Never commit `.env` with real credentials!

# ─── LLM Provider ──────────────────────────────────────────────
# Options: "bedrock" (production) | "groq" (development/speed)
LLM_PROVIDER=bedrock
LLM_MODEL=claude-sonnet-4

# ─── Amazon Bedrock (when LLM_PROVIDER=bedrock) ───────────────
# Authentication: env vars, AWS_PROFILE, or IAM role
AWS_REGION=ap-south-1
AWS_PROFILE=
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
BEDROCK_ROUTER_MODEL=claude-haiku

# ─── Groq (when LLM_PROVIDER=groq) ────────────────────────────
GROQ_API_KEY=

# ─── Together AI (backup) ─────────────────────────────────────
TOGETHER_API_KEY=

# ─── vLLM (self-hosted) ───────────────────────────────────────
VLLM_BASE_URL=http://localhost:8000/v1

# ─── Vector Database ──────────────────────────────────────────
# Options: "pgvector" (production/Aurora) | "qdrant" (development)
VECTOR_DB_PROVIDER=pgvector

# ─── Amazon Aurora PostgreSQL ─────────────────────────────────
# Single database for relational + vector data (pgvector)
PG_HOST=                          # Aurora endpoint e.g. cropfresh.cluster-xxx.ap-south-1.rds.amazonaws.com
PG_DATABASE=cropfresh
PG_PORT=5432
PG_USER=cropfresh_app
PG_PASSWORD=                      # Leave empty for IAM auth (production)
PG_USE_IAM_AUTH=false             # Set true in production

# ─── Qdrant (dev fallback, when VECTOR_DB_PROVIDER=qdrant) ────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=agri_knowledge

# ─── Neo4j (Graph Database) ───────────────────────────────────
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── Embeddings ────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# ─── External APIs ─────────────────────────────────────────────
AGMARKNET_API_KEY=
WEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Legacy Supabase (migration period) ────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ─── API Settings ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# ─── Security ──────────────────────────────────────────────────
API_KEY=
ALLOWED_ORIGINS=*

# ─── Observability ─────────────────────────────────────────────
OTEL_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cropfresh-ai

# ─── AI Kosha ──────────────────────────────────────────────────
AIKOSHA_API_KEY=
AIKOSHA_BASE_URL=https://indiaai.gov.in/api/v1

# ─── Feature Flags ─────────────────────────────────────────────
USE_ADAPTIVE_ROUTER=true
USE_REDIS_CACHE=true
ENABLE_RERANKER=true

# â”€â”€â”€ Sprint 08 Voice Bridge Services â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
VOICE_GATEWAY_HOST=0.0.0.0
VOICE_GATEWAY_PORT=3101
VOICE_GATEWAY_CORS_ORIGIN=*
VOICE_GATEWAY_ENABLE_LIVEKIT_BRIDGE=false
VOICE_GATEWAY_FALLBACK_WS_URL=ws://localhost:8000/api/v1/voice/ws/duplex
VOICE_GATEWAY_VAD_SERVICE_BASE_URL=http://localhost:8101
VOICE_GATEWAY_LIVEKIT_TTL=15m
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

VAD_SERVICE_HOST=0.0.0.0
VAD_SERVICE_PORT=8101
VAD_SERVICE_GRPC_HOST=0.0.0.0
VAD_SERVICE_GRPC_PORT=50061
VAD_SERVICE_MODEL_PATH=
